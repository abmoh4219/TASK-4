#!/bin/sh
# RegistrarOps Maven wrapper — uses installed mvn if available, otherwise
# downloads Apache Maven into .mvn/wrapper/dists and uses it.
set -e

if command -v mvn >/dev/null 2>&1; then
  exec mvn "$@"
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_DIR="$SCRIPT_DIR/.mvn/wrapper"
DIST_DIR="$WRAPPER_DIR/dists"
MVN_VERSION="3.9.6"
MVN_HOME="$DIST_DIR/apache-maven-$MVN_VERSION"

if [ ! -x "$MVN_HOME/bin/mvn" ]; then
  mkdir -p "$DIST_DIR"
  URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MVN_VERSION/apache-maven-$MVN_VERSION-bin.tar.gz"
  ARCHIVE="$DIST_DIR/apache-maven.tar.gz"
  echo "Downloading Apache Maven $MVN_VERSION..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$URL" -o "$ARCHIVE"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$URL" -O "$ARCHIVE"
  else
    echo "Error: need curl or wget to download Maven." >&2
    exit 1
  fi
  tar -xzf "$ARCHIVE" -C "$DIST_DIR"
  rm "$ARCHIVE"
fi

exec "$MVN_HOME/bin/mvn" "$@"
